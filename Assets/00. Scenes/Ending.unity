MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1367514266}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uADF8\uB807\uAC8C \uC8FC\uC778\uACF5\uC740 \uC57D \uD55C \uB2EC\uAC04
    \uB3C4\uC2EC \uACF3\uACF3\uC744 \uC5F4\uC2EC\uD788 \uCCAD\uC18C\uD558\uC600\uB2E4.\r\n\uADF8
    \uBAA8\uC2B5\uC744 \uBCF8 \uC9C0\uAD6C\uC778\uB4E4\uC774 \uC774\uC5D0 \uAC10\uBA85\uC744
    \uBC1B\uC544\r\n\uC804\uC138\uACC4\uAC00 \uC0DD\uD0DC\uC804\uD658\uC744 \uC9C4\uD589\uD574
    \uC9C0\uAD6C\uAC00 \uAE68\uB057\uD574\uC9C0\uAE30 \uC2DC\uC791\uD588\uB2E4.\r\n\r\n2025\uB144
    3\uC6D4 \uAE30\uC900, \uC11C\uC6B8 \uB4F1 \uC8FC\uC694 \uB300\uB3C4\uC2DC\uC758
    \uC5F0\uD3C9\uADE0 PM2.5 \uB18D\uB3C4\uB294 WHO \uAD8C\uACE0 \uAE30\uC900(5\u202F\xB5g/m\xB3)\uC744
    \uD06C\uAC8C \uC0C1\uD68C\uD55C 35\u202F~\u202F50\u202F\xB5g/m\xB3 \uC218\uC900\uC774\uC5C8\uB2E4.\r\n\uC774\uB294
    \uAC74\uAC15\uC5D0 \uC2EC\uAC01\uD55C \uC601\uD5A5\uC744 \uC8FC\uBA70, \uD638\uD761\uAE30\xB7\uC2EC\uD608\uAD00
    \uC9C8\uD658 \uBC0F \uC870\uAE30\uC0AC\uB9DD \uC99D\uAC00\uC640 \uACBD\uC81C\uC801
    \uBE44\uC6A9 \uAE09\uC99D \uB4F1 \uD658\uACBD\xB7\uAC74\uAC15\xB7\uACBD\uC81C
    \uBB38\uC81C\uB97C \uBCF5\uD569\uC801\uC73C\uB85C \uC77C\uC73C\uD0A4\uACE0 \uC788\uC5B4
    \uC2EC\uAC01\uD55C \uBB38\uC81C\uC600\uB2E4.\r\n\r\n\uD558\uC9C0\uB9CC \uC0AC\uB78C\uB4E4\uACFC
    \uD568\uAED8 \uD798\uC744 \uD569\uCE58\uBA70 \uD0C4\uC18C \uC911\uB9BD\uC744
    \uC9C0\uD0A4\uACE0, \uC790\uAC00\uC6A9 \uB300\uC2E0 \uB300\uC911\uAD50\uD1B5\uC744,
    \uC790\uB3D9\uCC28 \uB300\uC2E0 \uC790\uC804\uAC70\uC640 \uB3C4\uBCF4\uB97C \uC0AC\uC6A9\uD558\uBA70
    \uBBF8\uC138\uBA3C\uC9C0\uB294 \uC11C\uC11C\uD788 \uC904\uC5B4\uB4E4\uC5C8\uB2E4.\r\n\uB9CE\uC740
    \uC0AC\uB78C\uB4E4\uC758 \uB178\uB825\uC774 \uBAA8\uC5EC \uBBF8\uC138\uBA3C\uC9C0\uB294
    \uC5B4\uB290\uC0C8 \uC704\uD5D8 \uC218\uCE58\uB97C \uBC97\uC5B4\uB098\uAC8C \uB418\uC5C8\uACE0
    \uC8FC\uC778\uACF5\uC740 \uB9C8\uC2A4\uD06C\uB97C \uBC97\uC744 \uC218 \uC788\uC5C8\uB2E4.\r\n\r\n\uB610,
    \uD55C\uAD6D\uD574\uC591\uACFC\uD559\uAE30\uC220\uC6D0(KIOST) \uB4F1 \uACF5\uB3D9\uC5F0\uAD6C\uD300\uC740
    2003\uB144\uBD80\uD130 2023\uB144\uAE4C\uC9C0 20\uB144\uAC04 \uAD6D\uB0B4 \uC5F0\uC548\uC5D0\uC11C
    \uBC14\uB2F7\uC0C8, \uBC14\uB2E4\uAC70\uBD81, \uC5B4\uB958 \uB4F1 77\uC885\uC758
    \uD574\uC591\uC0DD\uBB3C 428\uAC74\uC758 \uD574\uC591\uC4F0\uB808\uAE30 \uC5BD\uD798
    \uD53C\uD574\uAC00 \uC788\uC5C8\uB2E4\uACE0 \uBC1D\uD614\uB2E4.\r\n\r\n\uC8FC\uC778\uACF5\uC740
    \uC774\uB97C \uD574\uACB0\uD558\uAE30 \uC704\uD574 \uC0AC\uB78C\uB4E4\uACFC \uD798\uC744
    \uD569\uCCD0 \uD574\uC591\uC744 \uC5F4\uC2EC\uD788 \uCCAD\uC18C\uD558\uBA70 \uBD88\uD544\uC694\uD55C
    \uD50C\uB77C\uC2A4\uD2F1 \uC0AC\uC6A9\uC744 \uC904\uC774\uBA70 \uD574\uC591 \uC4F0\uB808\uAE30\uB97C
    \uC904\uC774\uACE0, \uD30C\uAD34\uC801\uC778 \uC5B4\uC5C5\uC744 \uAE08\uC9C0\uD558\uB294
    \uCEA0\uD398\uC778\uC744 \uC9C4\uD589\uD558\uC5EC \uB04A\uC784\uC5C6\uC774 \uB178\uB825\uD558\uC600\uB2E4.
    \r\n\r\n\uADF8 \uACB0\uACFC \uD0DC\uD3C9\uC591 \uACF3\uACF3\uC5D0 \uC788\uB358
    \uC4F0\uB808\uAE30 \uC12C\uC740 \uC810\uCC28 \uC790\uCDE8\uB97C \uAC10\uCDC4\uACE0,
    \uD574\uC591 \uC4F0\uB808\uAE30\uB85C \uACE0\uD1B5\uBC1B\uB358 \uD574\uC591 \uC0DD\uBB3C\uB4E4\uB3C4
    \uC904\uC5B4\uB4E4\uC5C8\uB2E4.\r\n\uD574\uC591\uC4F0\uB808\uAE30 \uD0D3\uC5D0
    \uAD6D\uC81C\uC801\uC73C\uB85C \uBCF4\uD638\uAC00 \uD544\uC694\uD588\uB358 \uD574\uC591\uC0DD\uBB3C
    \uC911 \uC57D 13% (10\uC885, 44\uAC74)\uC774 IUCN \uC801\uC0C9\uBAA9\uB85D \uBA78\uC885\uC6B0\uB824\uC885\uB3C4
    \uB2E4\uC2DC \uB3CC\uC544\uC624\uB294 \uACC4\uAE30\uAC00 \uB418\uC5C8\uB2E4.\r\n\uD574\uC591\uC740
    \uC724\uD0DD\uD574\uC9C0\uACE0, \uC544\uB984\uB2E4\uC6B4 \uBC14\uB2E4\uB85C \uB3CC\uC544\uC654\uB2E4.\r\n\r\n\uC774\uB807\uAC8C
    \uC544\uB984\uB2E4\uC6CC\uC9C4 \uC9C0\uAD6C\uB97C \uBCF4\uBA70 \uC0AC\uB78C\uB4E4\uC740
    \uD55C \uAC00\uC9C0 \uC0DD\uAC01\uC744 \uD558\uAC8C \uB418\uC5C8\uB2E4\r\n\uC6B0\uB9AC\uB294
    \uC9C0\uAE08\uAE4C\uC9C0 \uB108\uBB34 \uADF9\uC2EC\uD55C \uC0B0\uC5C5\uD654\uC640
    \uB3C4\uC2DC\uD654\uB97C \uC9C4\uD589\uD588\uB358 \uAC83\uC774 \uC544\uB2D0\uAE4C?\r\n\uC774\uB7EC\uD55C
    \uACFC\uB3C4\uD55C \uC0B0\uC5C5\uD654\uAC00 \uBBF8\uC138\uBA3C\uC9C0\uC640 \uC774\uC0B0\uD654\uD0C4\uC18C\uB97C
    \uC99D\uAC00\uC2DC\uD0A4\uACE0, \uD574\uC591\uC4F0\uB808\uAE30\uC640 \uC9C0\uD558\uC218
    \uC624\uC5FC, \uC0B0\uB9BC \uBC8C\uCC44, \uC0DD\uD0DC\uACC4 \uD30C\uAD34\uC758
    \uBB38\uC81C\uAC00 \uC0DD\uACA8\uB09C \uAC83\uC774 \uC544\uB2D0\uAE4C?\r\n\r\n\uC0AC\uC2E4\uC740
    \uBAA8\uB450\uAC00 \uC54C\uACE0 \uC788\uC5C8\uC744\uC9C0\uB3C4 \uBAA8\uB978\uB2E4.
    \uD558\uC9C0\uB9CC \uC2E4\uCC9C\uD558\uC9C0 \uBABB\uD588\uB358 \uAC83\uC774\uB2E4.\r\n\uD558\uC9C0\uB9CC
    \uC8FC\uC778\uACF5\uC758 \uD589\uB3D9\uC744 \uACC4\uAE30\uB85C \uC0AC\uB78C\uB4E4\uC740
    \uB208\uC744 \uB728\uAC8C \uB418\uC5C8\uB2E4.\r\n\uC790\uC2E0\uB4E4\uC758 \uD589\uB3D9\uC744
    \uD6C4\uD68C\uD558\uACE0 \uC55E\uC73C\uB85C \uAC19\uC740 \uC2E4\uC218\uB97C \uBC18\uBCF5\uD558\uC9C0
    \uC54A\uAE30 \uC704\uD574 \uB178\uB825\uD574\uC57C \uACA0\uB2E4\uB294 \uACB0\uC2EC\uC744
    \uD558\uAC8C \uB41C \uAC83\uC774\uB2E4.\r\n\r\n\uC0AC\uB78C\uB4E4\uC740 \uAE30\uC874\uC758
    \uC0B0\uB9BC \uBC8C\uBAA9 \uB300\uC2E0 \uB098\uBB34\uB97C \uC2EC\uACE0, \uB3D9\uBB3C\uB4E4\uC744
    \uC0AC\uB0E5\uD558\uB294 \uB300\uC2E0 \uC0DD\uD0DC\uACC4\uB97C \uC720\uC9C0\uD558\uAE30
    \uC704\uD55C \uB2E8\uCCB4\uB97C \uC124\uB9BD\uD558\uAE30 \uC2DC\uC791\uD588\uB2E4.\r\n\uC9C0\uAD6C\uB294
    \uB2E4\uC2DC\uAE08 \uC0C1\uCF8C\uD558\uACE0 \uAE68\uB057\uD55C \uD658\uACBD\uC744
    \uB418\uCC3E\uC744 \uC218 \uC788\uC5C8\uB2E4.\r\n\r\n\r\n\r\n\r\n\r\n\uC5BC\uB9C8
    \uD6C4, \uC8FC\uC778\uACF5\uC740 \uCDA9\uACA9\uC801\uC778 \uC18C\uC2DD\uC744
    \uB4E3\uAC8C \uB41C\uB2E4.\r\n\r\n\uC5BC\uB9C8 \uC804\uAE4C\uC9C0\uB9CC \uD574\uB3C4
    \uC804 \uC6B0\uC8FC\uB97C \uCD1D\uAD04\uD558\uB294 \uC6B0\uC8FC \uD611\uD68C\uC5D0\uC11C\r\n\uC9C0\uAD6C\uAC00
    \uC6B0\uC8FC\uC758 \uBBF8\uAD00\uC744 \uD574\uCE58\uB2C8 \uC5C6\uC560\uC790\uB294
    \uC758\uACAC\uC774 \uB098\uC640 \uC9C0\uAD6C\uAC00 \uD30C\uBA78\uC758 \uC704\uAE30\uC5D0
    \uCC98\uD574\uC788\uC5C8\uB358 \uAC83\uC774\uB2E4.\r\n\r\n\uD558\uC9C0\uB9CC
    \uAE68\uB057\uD55C \uC9C0\uAE08\uC758 \uC9C0\uAD6C\uB97C \uBCF8 \uC6B0\uC8FC
    \uD611\uD68C\uB294 \uC9C0\uAD6C\uD3D0\uAE30\uACC4\uD68D\uC744 \uCCA0\uD68C\uD558\uC5EC
    \uC9C0\uAD6C\uB294 \uD30C\uBA78\uC758 \uC704\uAE30\uC5D0\uC11C \uBC97\uC5B4\uB0A0
    \uC218 \uC788\uC5C8\uB2E4.\r\n\uC9C0\uAD6C\uC758 \uC601\uC6C5\uC774 \uB41C \uC8FC\uC778\uACF5\uC740
    \uC804\uC138\uACC4\uC5D0\uC11C \uCE6D\uC1A1\uBC1B\uC73C\uBA70 \uACF3\uACF3\uC5D0
    \uAE08\uB3D9\uC0C1\uC774 \uC138\uC6CC\uC9C0\uACE0 \uADF8\uC758 \uC704\uC778\uC804\uC774
    \uB300\uB300\uB85C \uAD50\uACFC\uC11C\uC5D0 \uC2E4\uB838\uB2E4.\r\n\r\n\uC6B0\uC8FC
    \uD611\uD68C\uB294 \uC8FC\uC778\uACF5\uC5D0\uAC8C\r\n\"\uC9C0\uAD6C \uBD80\uC218\uAE30
    \uADC0\uCC2E\uC558\uB294\uB370 \uCCAD\uC18C\uD574\uC918\uC11C \uACE0\uB9D9\uB2E4\"\r\n\uB77C\uB294
    \uB0B4\uC6A9\uC758 \uD3B8\uC9C0\uB97C \uC6B4\uC11D\uC5D0 \uB2F4\uC544 \uC8FC\uC778\uACF5\uC758
    \uC9D1\uC73C\uB85C \uC3D8\uC558\uB2E4.\r\n\uBE44\uB85D \uC8FC\uC778\uACF5\uC758
    \uC9D1\uC740 \uBD80\uC234\uC92C\uC9C0\uB9CC \uC6B0\uC8FC \uD611\uD68C\uC758 \uBA54\uC138\uC9C0\uB294
    \uADF8\uC758 \uC2EC\uAE08\uC744 \uC6B8\uB838\uB2E4.\r\n\r\n\uC4F0\uB808\uAE30
    \uC12C \uB54C\uBB38\uC5D0 \uACE8\uCE58 \uC544\uD30C\uD558\uB358 \uD574\uB140\uB4E4\uC740\r\n\uC8FC\uC778\uACF5\uC5D0\uAC8C
    \uC131\uAC8C 500\uAC1C\uC640 \uC804\uBCF5 375\uAC1C\uB97C \uC120\uBB3C\uD588\uB2E4.\r\n\uBC14\uB2E4\uC758
    \uC544\uB984\uB2E4\uC6B4 \uC0DD\uD0DC\uAC00 \uB3CC\uC544\uC624\uBA74\uC11C \uC131\uAC8C\uB4E4\uACFC
    \uC804\uBCF5\uB4E4\uB3C4 \uC8FC\uC778\uACF5\uC5D0\uAC8C \uAC10\uC0AC\uB97C \uD45C\uD588\uB2E4.\r\n\r\n\uC8FC\uC778\uACF5\uC774
    \uB9AC\uC0AC\uC774\uD074\uB9C1 \uC7A5\uBE44\uB85C \uC774\uB7EC\uD55C \uC0DD\uD0DC\uC804\uD658\uC744
    \uC2E4\uCC9C\uD588\uB2E4\uB294 \uC0AC\uC2E4\uC774 \uC54C\uB824\uC9C0\uBA74\uC11C\r\n\uC804\uC138\uACC4\uC758
    \uB9AC\uC0AC\uC774\uD074\uB9C1 \uC758\uB958 \uD68C\uC0AC\uC5D0\uC11C \uAD11\uACE0\uB97C
    \uBC1B\uC558\uB2E4.\r\n\uC8FC\uC778\uACF5\uC740 \uB9AC\uC0AC\uC774\uD074\uB9C1
    \uB300\uD45C \uC570\uBC84\uC11C\uB354\uAC00 \uB418\uC5B4 \uD3C9\uC0DD \uCE5C\uD658\uACBD
    \uC758\uB958\uB97C \uC785\uC744 \uC218 \uC788\uAC8C \uB418\uC5C8\uB2E4.\r\n\r\n\uC774\uD6C4
    \uC8FC\uC778\uACF5\uC758 \uB3D9\uC0C1\uACFC \uAD11\uACE0\uB97C \uBCF8 \uC5F0\uB77D\uC744
    \uB2E8 \uD55C \uBC88\uB3C4 \uD558\uC9C0 \uC54A\uB358 \uCD08\uB4F1\uD559\uAD50,
    \uC911\uD559\uAD50, \uACE0\uB4F1\uD559\uAD50 \uB3D9\uCC3D\uB4E4\uC740\r\n\uC8FC\uC778\uACF5\uC5D0\uAC8C
    \uBC25 \uD55C \uBC88 \uC0AC\uB77C\uBA70 \uC5F0\uB77D\uC744 \uD574\uC624\uAE30
    \uC2DC\uC791\uD588\uB2E4.\r\n\uC8FC\uC778\uACF5\uC740 \uC774\uB97C \uC4F0\uB808\uAE30\uB77C\uACE0
    \uCE6D\uD558\uBA70 \uB2E4\uC2DC \uD55C \uBC88 \uC4F0\uB808\uAE30 \uCCAD\uC18C\uB97C
    \uD558\uC600\uB2E4.\r\n\r\n\uC804\uC138\uACC4\uC801\uC73C\uB85C \uC9C4\uD589\uB41C
    \uC9C0\uC18D \uAC00\uB2A5\uD55C \uC0DD\uD65C \uC2E4\uD604\uC740\r\n\uBD81\uADF9\uACFC
    \uB0A8\uADF9\uC5D0\uB3C4 \uC601\uD5A5\uC744 \uB07C\uCE58\uAC8C \uB418\uC5C8\uB2E4.\r\n\r\n\uBD81\uADF9\uC5D0\uB294
    \uAE30\uC628\uC774 \uB3CC\uC544\uC640 \uBE59\uD558\uB294 \uB2E4\uC2DC \uB3CC\uC544\uC654\uACE0,\r\n\uC0AC\uB0E5\uC744
    \uC2DC\uC791\uD560 \uC218 \uC788\uAC8C \uB41C \uBD81\uADF9\uACF0\uB4E4\uC740
    \uD65C\uAE30\uB97C \uB418\uCC3E\uC544\r\n\uC8FC\uC778\uACF5\uC5D0\uAC8C \uCF5C\uB77C\uB97C
    \uB9C8\uC2DC\uB294 \uC601\uC0C1\uD3B8\uC9C0\uB97C \uBCF4\uB0B4\uC5B4 \uADFC\uD669\uC744
    \uC804\uD588\uB2E4.\r\n\r\n\uD3AD\uADC4\uC758 \uB300\uD45C [\uD3F4\uB77C\uB808\uD2F0]\uB294
    \r\n\uC9C1\uC811 \uC8FC\uC778\uACF5\uC758 \uC9D1\uAE4C\uC9C0 \uB0B4\uB824\uC640
    \uC2E0\uC120\uD55C \uD3F4\uB77C\uB808\uD2F0 756\uAC1C\uB97C \uC120\uBB3C\uD574\uC8FC\uC5C8\uB2E4.\r\n\uD558\uC9C0\uB9CC
    \uC8FC\uC778\uACF5\uC758 \uB0C9\uB3D9\uC2E4\uC774 \uAF49 \uCC28\uC11C \uB0C9\uC7A5\uACE0\uB97C
    \uD558\uB098 \uB354 \uC0AC\uB294 \uD070 \uC9C0\uCD9C\uC774 \uC788\uC5B4\uC57C
    \uD588\uB2E4.\r\n\uB0C9\uC7A5\uACE0\uB97C \uC0AC\uBA74 \uC804\uAE30\uC138\uAC00
    \uB354 \uB098\uAC00\uAE30\uC5D0 \uC8FC\uC778\uACF5\uC740 \uC9C1\uC811 \uD3F4\uB77C\uB808\uD2F0
    \uC804\uC6A9 \uC11D\uBE59\uACE0\uB97C \uC190\uC218 \uB9CC\uB4E4\uC5B4 \uD3F4\uB77C\uB808\uD2F0\uB97C
    \uBCF4\uAD00\uD558\uC600\uB2E4.\r\n\uADF8\uB807\uAC8C \uC9C0\uC18D \uAC00\uB2A5\uD55C
    \uC0DD\uD65C\uC744 \uC9C0\uC18D\uD560 \uC218 \uC788\uAC8C \uB418\uC5C8\uB2E4.\r\n\r\n\uC8FC\uC778\uACF5\uC758
    \uC5B4\uBA38\uB2C8\uC640 \uC544\uBC84\uC9C0\uB294\r\n\"\uB3D9\uC900\uC544, \uB124\uAC00
    \uC815\uB9D0 \uC7A5\uD558\uB2E4.\" \r\n\uB77C\uB294 \uB9D0\uC744 \uB0A8\uACBC\uB2E4.\r\n\uD3C9\uC18C
    \uB300\uD654\uB3C4 \uD558\uC9C0 \uC54A\uC558\uB358 \uBD80\uBAA8\uB2D8\uC758 \uB530\uB73B\uD55C
    \uB9D0\uC744 \uB4E3\uACE0 \uC8FC\uC778\uACF5\uC740 \uAC10\uB3D9\uC758 \uB208\uBB3C\uC744
    \uD758\uB838\uB2E4.\r\n\r\n\uD558\uC9C0\uB9CC \uC8FC\uC778\uACF5\uC758 \uC5BC\uAD74\uC774
    \uB108\uBB34 \uB9CE\uC774 \uD314\uB9B0 \uB098\uBA38\uC9C0\r\n\uC8FC\uC778\uACF5\uC774
    \uD3B8\uC758\uC810\uB9CC \uB098\uAC00\uB3C4 \uC0AC\uB78C\uB4E4\uC740 \uC8FC\uC778\uACF5\uC5D0\uAC8C
    \uC0AC\uC778\uC744 \uC694\uAD6C\uD558\uAC70\uB098 \uB9B4\uC2A4\uC5D0 \uC62C\uB9AC\uB294
    \uB4F1 \uAC10\uB2F9\uD560 \uC218 \uC5C6\uB294 \uAD00\uC2EC\uC744 \uBC1B\uAC8C
    \uB418\uC5C8\uB2E4.\r\n\uBD80\uB2F4\uC744 \uB290\uB080 \uC8FC\uC778\uACF5\uC740
    \uB2E4\uC2DC \uBC29\uAD6C\uC11D \uC0DD\uD65C\uB85C \uB3CC\uC544\uAC00 \uD589\uBC29\uC744
    \uC608\uCE21\uD560 \uC218 \uC5C6\uAC8C \uB418\uC5C8\uB2E4.\r\n\uB2E4\uC2DC \uC624\uD0C0\uCFE0
    \uC0DD\uD65C\uC744 \uD558\uAC8C \uB418\uBA74\uC11C \uBD80\uBAA8\uB2D8\uC758 \uAD00\uC2EC\uC740
    \uC6D0\uB798\uB300\uB85C \uB3CC\uC544\uC654\uB2E4\uACE0 \uD55C\uB2E4.\r\n\r\n\uC8FC\uC778\uACF5\uC740
    \uBC29\uC5D0 \uB4E4\uC5B4\uC11C\uC790\uB9C8\uC790 \uCDA9\uACA9\uC801\uC778 \uAD11\uACBD\uC744
    \uBAA9\uB3C4\uD55C\uB2E4.\r\n\uC57D \uD55C \uB2EC\uAC04 \uC8FC\uC778\uACF5\uC774
    \uC0DD\uD0DC\uC804\uD658 \uD50C\uB85C\uAE45\uC744 \uC9C4\uD589\uD558\uBA74\uC11C\r\n\uBC29\uC5D0
    \uC804\uC2DC\uB418\uC5B4\uC788\uB358 \uBAA8\uB4E0 \uD55C\uBC1C\uB85C \uC11C\uC788\uB358
    \uCE90\uB9AD\uD130 \uD53C\uADDC\uC5B4\uB4E4\uC774 \uADF8\uB3D9\uC548\uC758 \uC9C0\uAD6C\uC628\uB09C\uD654\uC640
    \uC911\uB825\uC758 \uC601\uD5A5\uC73C\uB85C \uBCC0\uD615\uB418\uC5B4 \uADE0\uD615\uC744
    \uC783\uACE0 \uB9C8\uC774\uD074 \uC7AD\uC2A8\uC774 \uB418\uC5B4\uC788\uC5C8\uB2E4.\r\n\uD558\uC9C0\uB9CC
    \uC8FC\uC778\uACF5\uC740 \uB9AC\uC0AC\uC774\uD074\uB9C1 \uC570\uBC84\uC11C\uB354\uB85C
    \uD65C\uB3D9\uD558\uBA74\uC11C \uB9CE\uC740 \uC790\uBCF8\uC744 \uC5BB\uC5C8\uAE30
    \uB54C\uBB38\uC5D0\r\n\uC0C8\uB85C\uC6B4 \uD53C\uADDC\uC5B4\uB97C \uAD6C\uB9E4\uD558\uC5EC
    \uB2E4\uC2DC \uD589\uBCF5\uD574\uC84C\uB2E4.\r\n\r\n\uADF8\uB9AC\uD558\uC5EC
    \uC9C0\uAD6C\uB294 \uC6B0\uB9AC\uC758 \uB178\uB825\uC73C\uB85C \uB3CC\uC544\uC62C
    \uC218 \uC788\uC5C8\uACE0\r\n\uBAA8\uB450\uAC00 \uD589\uBCF5\uD55C \uC9C0\uAD6C\uB97C
    \uC9C0\uCF1C\uB0BC \uC218 \uC788\uC5C8\uB2E4.\r\n\r\n\r\n\uAE30\uD68D \uBC0F
    \uAC1C\uBC1C: \uAE40\uCC2C\uC6B0, \uAE40\uD76C\uC218\r\n\uB514\uC790\uC778: \uAE40\uC11C\uC601,
    \uC704\uC11C\uD604\r\n\r\nThank You for Playing"
